@model RestauranteReserva.Models.Mesa
@{
    ViewData["Title"] = "Nova Mesa";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Nova Mesa</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="Numero" class="form-label">Número da Mesa</label>
                            <input asp-for="Numero" type="number" min="1" class="form-control"/>
                            <span asp-validation-for="Numero" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Capacidade" class="form-label">Capacidade (pessoas)</label>
                            <input asp-for="Capacidade" type="number" min="1" class="form-control"/>
                            <span asp-validation-for="Capacidade" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Disponivel" class="form-label">Status</label>
                            <select asp-for="Disponivel" class="form-select">
                                <option value="true">Disponível</option>
                                <option value="false">Ocupada</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Salvar</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>