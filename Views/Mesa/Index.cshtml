@model IEnumerable<RestauranteReserva.Models.Mesa>
@{
    ViewData["Title"] = "Mesas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🪑 Mesas</h2>
        <a asp-action="Create" class="btn btn-success">+ Nova Mesa</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Nenhuma mesa cadastrada ainda.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Número</th>
                    <th>Capacidade</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>Mesa @m.Numero</td>
                        <td>@m.Capacidade pessoas</td>
                        <td>
                            @if (m.Disponivel)
                            {
                                <span class="badge bg-success">Disponível</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ocupada</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-danger">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>