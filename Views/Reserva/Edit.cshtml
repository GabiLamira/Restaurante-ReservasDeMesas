@model RestauranteReserva.Models.Reserva
@{
    ViewData["Title"] = "Editar Reserva";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">Editar Reserva</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id"/>

                        <div class="mb-3">
                            <label asp-for="NomeCliente" class="form-label">Nome do Cliente</label>
                            <input asp-for="NomeCliente" class="form-control"/>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telefone" class="form-label">Telefone</label>
                            <input asp-for="Telefone" class="form-control"/>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DataHora" class="form-label">Data e Hora</label>
                            <input asp-for="DataHora" type="datetime-local" class="form-control"/>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NumeroPessoas" class="form-label">Número de Pessoas</label>
                            <input asp-for="NumeroPessoas" type="number" min="1" class="form-control"/>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MesaId" class="form-label">Mesa</label>
                            <select asp-for="MesaId" class="form-select">
                                @foreach (var mesa in ViewBag.Mesas as List<RestauranteReserva.Models.Mesa> ?? new())
                                {
                                    <option value="@mesa.Id">Mesa @mesa.Numero (até @mesa.Capacidade pessoas)</option>
                                }
                            </select>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Salvar Alterações</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>